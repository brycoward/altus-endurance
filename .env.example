# ── Required ──────────────────────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_strong_random_secret

# Strong password for the Postgres database
POSTGRES_PASSWORD=replace_with_a_strong_db_password

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: anthropic, openai, deepseek, google
LLM_PROVIDER=anthropic
LLM_API_KEY=your_api_key_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Dev default: http://localhost:5174
# Production: set to your domain (e.g. https://altus.example.com)
FRONTEND_ORIGIN=http://localhost:5174

# ── Optional ──────────────────────────────────────────────────────────────────
# Set to "true" to print every request to container logs
DEBUG_REQUESTS=false

# Telegram bot (leave blank if not using)
TELEGRAM_BOT_TOKEN=
