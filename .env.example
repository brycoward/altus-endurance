# ── Required ──────────────────────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_strong_random_secret

# Strong password for the Postgres database
POSTGRES_PASSWORD=replace_with_a_strong_db_password

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_API_KEY=your_anthropic_or_openai_key_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to the URL you use to access the frontend (e.g. your home lab IP)
# Default: http://localhost:5174
FRONTEND_ORIGIN=http://localhost:5174

# ── Optional / Debug ──────────────────────────────────────────────────────────
# Set to "true" to print every request to container logs
DEBUG_REQUESTS=false

# Telegram bot (leave blank if not using)
TELEGRAM_BOT_TOKEN=
